@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix : <http://example.org/rules/> .
@prefix schema: <http://schema.org/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix d3f: <http://d3fend.mitre.org/ontologies/d3fend.owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix uco: <http://purl.org/cyber/uco#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.org/cyber/uco#> .

# Logical Source Definition
[] a rr:TriplesMap;
  rml:logicalSource [
    rml:source "./rml_mapper/d3fend/d3fend_data.json";
    rml:referenceFormulation ql:JSONPath;
    rml:iterator "d3fend[*]"
  ];
  rr:subjectMap [
    rr:template "http://purl.org/cyber/uco#VULN-{d3f.id}";
    rr:class uco:ucoVulnerability
  ].

[] a rr:TriplesMap;
  rr:subjectMap [
    rr:template "http://purl.org/cyber/uco#{d3f.id}";
    rr:class uco:ucoCWE
  ].

[] a rr:TriplesMap;
  rr:subjectMap [
    rr:template "http://purl.org/cyber/uco#ExploitTarget-{weakness-of}";
    rr:class uco:ucoExploitTarget
  ].

[] rr:predicateObjectMap [
  rr:predicate uco:ucohasVulnerability;
  rr:objectMap [
    rr:parentTriplesMap [
      rr:template "http://purl.org/cyber/uco#VULN-{d3f.id}";
      rr:class uco:ucoVulnerability
    ];
    rr:joinCondition [
      rr:child "d3f.id";
      rr:parent "d3f.id"
    ]
  ]
].

[] rr:predicateObjectMap [
  rr:predicate uco:ucohasVulnerability;
  rr:objectMap [
    rr:parentTriplesMap [
      rr:template "http://purl.org/cyber/uco#ExploitTarget-{weakness-of}";
      rr:class uco:ucoExploitTarget
    ];
    rr:joinCondition [
      rr:child "weakness-of";
      rr:parent "d3f.cwe-id"
    ]
  ]
].

[] rr:predicateObjectMap [
  rr:predicate uco:ucoPublishedDate;
  rr:objectMap [
    rml:reference "d3f.published";
    rr:datatype xsd:dateTime
  ]
].