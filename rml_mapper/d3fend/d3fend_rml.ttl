@prefix attack: <http://purl.org/cyber/attack#> .
@prefix d3fend: <http://purl.org/cyber/d3fend#> .
@prefix uco: <http://purl.org/cyber/uco#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.org/cyber/uco#> .

# How to read D3FEND data from JSON and iterate
uco:ClassEMap a rr:TriplesMap;
  rml:logicalSource [
    rml:source "/vol/data/d3fend.json";  # Adjusted logical source for D3FEND data
    rml:referenceFormulation ql:JSONPath;
    rml:iterator "$.@graph[*]"
  ].

# Subject mapping for D3FEND data
uco:ClassEMap rr:subjectMap [
  rr:template "http://purl.org/cyber/d3fend#Technique-{@id}";
  rr:class d3fend:Technique
].

# Mapping d3fend:off_tech_id to attack:id
uco:ClassEMap rr:predicateObjectMap [
  rr:predicate attack:id;
  rr:objectMap [
    rr:parentTriplesMap uco:ClassDMap;  # Referencing the ATT&CK map
    rr:joinCondition [
      rr:child "off_tech_id";  # Using the off_tech_id from the D3FEND data
      rr:parent "@id"  # Mapping to the id in the ATT&CK map
    ]
  ]
].

# Class D mapping for ATT&CK data
uco:ClassDMap a rr:TriplesMap;
  rml:logicalSource [
    rml:source "/vol/data/attack.json";  # Adjusted logical source for ATT&CK data
    rml:referenceFormulation ql:JSONPath;
    rml:iterator "$.@graph[*]"
  ].

# Subject mapping for ATT&CK JSON data
uco:ClassDMap rr:subjectMap [
  rr:template "http://purl.org/cyber/attack#Technique-{@id}";
  rr:class attack:Technique
].
