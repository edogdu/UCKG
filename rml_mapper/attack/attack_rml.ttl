@prefix attack: <http://purl.org/cyber/attack#> .
@prefix capec: <http://purl.org/cyber/capec#> .
@prefix d3fend: <http://purl.org/cyber/d3fend#> .
@prefix uco: <http://purl.org/cyber/uco#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.org/cyber/uco#> .

# How to read ATT&CK data from JSON and iterate
uco:ClassDMap a rr:TriplesMap;
  rml:logicalSource [
    rml:source "/vol/data/attack.json";
    rml:referenceFormulation ql:JSONPath;
    rml:iterator "$.@graph[*]"
  ].

# Subject mapping for ATT&CK JSON data
uco:ClassDMap rr:subjectMap [
  rr:template "{@id}";
  rr:class uco:attackEntry
].

# Mapping id to capec:Related_Weaknesses
uco:ClassDMap rr:predicateObjectMap [
  rr:predicate capec:Related_Weaknesses;
  rr:objectMap [
    rr:parentTriplesMap uco:ClassAMap;  # Referencing the CAPEC map
    rr:joinCondition [
      rr:child "@id";  # Using the id from the ATT&CK data
      rr:parent "capec:Related_Weakness/capec:ID"  # Mapping to the ID in the CAPEC map
    ]
  ]
].

# Class A mapping for CAPEC data
uco:ClassAMap a rr:TriplesMap;
  rml:logicalSource [
    rml:source "/vol/data/capec.json";
    rml:referenceFormulation ql:XPath;
    rml:iterator "/capec:CAPEC/capec:Attack_Patterns/capec:Attack_Pattern"
  ].

# Subject mapping for CAPEC data
uco:ClassAMap rr:subjectMap [
  rr:template "http://purl.org/cyber/capec#Attack-{capec:ID}";
  rr:class capec:Attack_Pattern
].

# Mapping capec:Related_Weaknesses to id
uco:ClassAMap rr:predicateObjectMap [
  rr:predicate attack:id;
  rr:objectMap [
    rr:parentTriplesMap uco:ClassDMap;  # Referencing the ATT&CK map
    rr:joinCondition [
      rr:child "capec:Related_Weakness/capec:ID";  # Using the ID from the CAPEC data
      rr:parent "@id"  # Mapping to the id in the ATT&CK map
    ]
  ]
].

# Mapping id to d3fend:off_tech_id
uco:ClassDMap rr:predicateObjectMap [
  rr:predicate d3fend:off_tech_id;
  rr:objectMap [
    rr:parentTriplesMap uco:ClassEMap;  # Referencing the D3FEND map
    rr:joinCondition [
      rr:child "@id";  # Using the id from the ATT&CK data
      rr:parent "d3fend:off_tech_id"  # Mapping to the off_tech_id in the D3FEND map
    ]
  ]
].

# Class E mapping for D3FEND data
uco:ClassEMap a rr:TriplesMap;
  rml:logicalSource [
    rml:source "/vol/data/d3fend.json";
    rml:referenceFormulation ql:XPath;
    rml:iterator "/d3fend:D3FEND/d3fend:Techniques/d3fend:Technique"
  ].

# Subject mapping for D3FEND data
uco:ClassEMap rr:subjectMap [
  rr:template "http://purl.org/cyber/d3fend#Technique-{d3fend:Technique_ID}";
  rr:class d3fend:Technique
].
