@prefix capec: <http://purl.org/cyber/capec#> .
@prefix stucco: <http://stucco.mitre.org/> .
@prefix uco: <http://purl.org/cyber/uco#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.org/cyber/uco#> .

# How to read CAPEC data from XML and iterate
uco:ClassAMap a rr:TriplesMap;
  rml:logicalSource [
    rml:source "/vol/data/capec.json";
    rml:referenceFormulation ql:XPath;
    rml:iterator "/capec:CAPEC/capec:Attack_Patterns/capec:Attack_Pattern"
  ].

# CAPEC Attack Pattern mapping
uco:ClassAMap rr:subjectMap [
  rr:template "http://purl.org/cyber/capec#Attack-{capec:ID}";
  rr:class capec:Attack_Pattern
].

# Mapping related weaknesses to CWEs
uco:ClassAMap rr:predicateObjectMap [
  rr:predicate capec:Related_Weaknesses;
  rr:objectMap [
    rr:parentTriplesMap uco:ClassCMap;  # Referencing the CWE map
    rr:joinCondition [
      rr:child "capec:Related_Weakness/capec:ID";  # Using the ID of the related weakness
      rr:parent "cwe.id_value"  # Mapping to the CWE ID value
    ]
  ]
].

# Class C mapping for CWEs
uco:ClassCMap a rr:TriplesMap;
  rml:logicalSource [
    rml:source "./rml_mapper/cwe/cwes.json";
    rml:referenceFormulation ql:JSONPath;
    rml:iterator "cwes[*]"
  ].

# Subject mapping for CWEs
uco:ClassCMap rr:subjectMap [
  rr:template "http://purl.org/cyber/uco#ExploitTarget-{cwe.id_value}";
  rr:class uco:ucoExploitTarget
].

# Mapping id to taxonomy_mappings
uco:ClassAMap rr:predicateObjectMap [
  rr:predicate capec:taxonomy_mapping;
  rr:objectMap [
    rr:parentTriplesMap uco:ClassDMap;  # Referencing the ATT&CK map
    rr:joinCondition [
      rr:child "capec:taxonomy_mapping/capec:off_tech_id";  # Using the off_tech_id from the taxonomy mapping
      rr:parent "attack:id"  # Mapping to the id in the ATT&CK map
    ]
  ]
].

# Class D mapping for ATT&CK data
uco:ClassDMap a rr:TriplesMap;
  rml:logicalSource [
    rml:source "/vol/data/attack.json";
    rml:referenceFormulation ql:XPath;
    rml:iterator "/attack:ATTACK/attack:Techniques/attack:Technique"
  ].

# Subject mapping for ATT&CK data
uco:ClassDMap rr:subjectMap [
  rr:template "http://purl.org/cyber/attack#Technique-{attack:Technique_ID}";
  rr:class attack:Technique
].
